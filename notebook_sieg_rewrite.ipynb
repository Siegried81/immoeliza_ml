   "source": [
    "# Immo Eliza — Cleaned Notebook (unified preprocessing + training)\n",
    "\n",
    "This notebook is a rewritten, cleaned, and reproducible version of the exploratory notebook. It centralizes preprocessing into a single pipeline, avoids data leakage by fitting transforms on the training set only, uses a consistent target transform (log1p / expm1), and saves trained pipelines with joblib.\n",
    "\n",
    "Cells are structured to: clean data → inspect missing values → build preprocessor → split → train models (Linear, RandomForest, XGBoost) → evaluate → save artifacts → provide a predict helper."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# Imports\n",
    "import os\n",
    "import json\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import joblib\n",
    "\n",
    "from sklearn.pipeline import Pipeline\n",
    "from sklearn.compose import ColumnTransformer, TransformedTargetRegressor\n",
    "from sklearn.impute import SimpleImputer\n",
    "from sklearn.preprocessing import StandardScaler, OneHotEncoder, OrdinalEncoder\n",
    "from sklearn.model_selection import train_test_split, cross_val_score\n",
    "from sklearn.linear_model import LinearRegression\n",
    "from sklearn.ensemble import RandomForestRegressor\n",
    "from sklearn.metrics import mean_squared_error, r2_score, mean_absolute_error\n",
    "import xgboost as xgb\n",
    "\n",
    "# constants / paths (relative paths so the notebook can run in CI or locally)\n",
    "INPUT_FILE = 'data/raw/dataframe.json'\n",
    "OUTPUT_DIR = 'data/clean'\n",
    "OUTPUT_FILE = os.path.join(OUTPUT_DIR, 'cleaned_data.json')\n",
    "MODEL_DIR = 'models'\n",
    "RANDOM_STATE = 42\n",
    "\n",
    "os.makedirs(OUTPUT_DIR, exist_ok=True)\n",
    "os.makedirs(MODEL_DIR, exist_ok=True)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "def dataframe_cleaner(input_path, output_path):\n",
    "    \"\"\"\n",
    "    Load raw json, drop duplicates, coerce numeric columns, rename nicely, fill expected NA and return cleaned dataframe.\n",
    "    The function writes a pretty JSON to output_path and returns the dataframe (pandas).\n",
    "    \"\"\"\n",
    "    df = pd.read_json(input_path)\n",
    "\n",
    "    # basic dedup and type corrections\n",
    "    clean_df = df.drop_duplicates(subset=['postcode', 'price', 'livable_surface', 'address']).copy()\n",
    "    # create derived features\n",
    "    clean_df['price_per_m2'] = clean_df['price'] / clean_df['livable_surface']\n",
    "\n",
    "    cols_to_int = [\"postcode\", \"price\", \"build_year\", \"bedroom_count\", \"livable_surface\", \n",
    "                   \"total_surface\", \"garage\", \"terrace\", \"swimming_pool\", \"peb_category\", \n",
    "                   \"Preschool_distance\", \"Train_station_distance\", \"Supermarket_distance\"]\n",
    "\n",
    "    for col in cols_to_int:\n",
    "        if col in clean_df.columns:\n",
    "            clean_df[col] = pd.to_numeric(clean_df[col], errors='coerce')\n",
    "\n",
    "    new_column_names = {\"peb_category\": \"energy_consumption_kWh/m2/year\",\n",
    "                        \"Preschool_distance\": \"preschool_distance_m\",\n",
    "                        \"Train_station_distance\": \"train_station_distance_m\",\n",
    "                        \"Supermarket_distance\": \"supermarket_distance_m\",\n",
    "                        \"distance_nearest_city\": \"nearest_city_distance_km\"}\n",
    "    clean_df = clean_df.rename(columns=new_column_names)\n",
    "\n",
    "    text_cols = ['city', 'province', 'address', 'nearest_city']\n",
    "    import html\n",
    "    for col in text_cols:\n",
    "        if col in clean_df.columns:\n",
    "            clean_df[col] = clean_df[col].apply(lambda x: html.unescape(x) if isinstance(x, str) else x)\n",
    "\n",
    "    # sensible defaults\n",
    "    if 'garage' in clean_df.columns:\n",
    "        clean_df['garage'] = clean_df['garage'].fillna(0)\n",
    "    if 'swimming_pool' in clean_df.columns:\n",
    "        clean_df['swimming_pool'] = clean_df['swimming_pool'].fillna(0)\n",
    "\n",
    "    if 'property_state' in clean_df.columns:\n",
    "        clean_df['property_state'] = clean_df['property_state'].replace('To be renovated', 'To renovate')\n",
    "\n",
    "    # Save cleaned file (utf-8, orient records)\n",
    "    os.makedirs(os.path.dirname(output_path), exist_ok=True)\n",
    "    clean_df.to_json(output_path, orient='records', force_ascii=False, indent=4)\n",
    "\n",
    "    return clean_df\n",
    "\n",
    "# Run cleaner (if file exists)\n",
    "if os.path.exists(INPUT_FILE):\n",
    "    df_cleaned = dataframe_cleaner(INPUT_FILE, OUTPUT_FILE)\n",
    "else:\n",
    "    print(f'Input file {INPUT_FILE} not found. Please place your raw dataframe at this path.')\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "def plot_missing_values(df):\n",
    "    total_rows = len(df)\n",
    "    nan_counts = df.isnull().sum()\n",
    "    nan_cols = nan_counts[nan_counts > 0].sort_values(ascending=False)\n",
    "    if nan_cols.empty:\n",
    "        print('No missing values found.')\n",
    "        return\n",
    "    plt.figure(figsize=(12, 6))\n",
    "    bars = nan_cols.plot(kind='bar', color='orange', edgecolor='k')\n",
    "    for p in bars.patches:\n",
    "        percentage = f"{(p.get_height() / total_rows) * 100:.1f}%"\n",
    "        plt.text(p.get_x() + p.get_width() / 2, p.get_height(), percentage, ha='center', va='bottom')\n",
    "    plt.title('Columns with Missing Values')\n",
    "    plt.xlabel('Columns')\n",
    "    plt.ylabel('Number of missing values')\n",
    "    plt.xticks(rotation=45, ha='right')\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "# Use df_cleaned if available\n",
    "try:\n",
    "    plot_missing_values(df_cleaned)\n",
    "except NameError:\n",
    "    print('df_cleaned not available. Run the cleaner first.')\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Preprocessing pipeline (single, reusable)\n",
    "\n",
    "We will: group rare categories (top-k), impute numerics with median, scale numerics for linear models, encode categoricals differently for tree vs linear models. We will always fit transformers on train set only to avoid leakage."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "from sklearn.base import TransformerMixin, BaseEstimator\n",
    "\n",
    "class TopKCategoricalGrouper(TransformerMixin, BaseEstimator):\n",
    "    \"\"\"Group rare categories into '__other__' using training fit.\n",
    "    Keeps the top_k categories seen during fit; transforms unseen to '__other__'.\n",
    "    \"\"\"\n",
    "    def __init__(self, top_k=50):\n",
    "        self.top_k = top_k\n",
    "        self.top_categories_ = {}\n",
    "    def fit(self, X, y=None):\n",
    "        # X is expected to be a DataFrame\n",
    "        if isinstance(X, (pd.Series, np.ndarray)):\n",
    "            X = pd.DataFrame(X)\n",
    "        for col in X.columns:\n",
    "            self.top_categories_[col] = X[col].value_counts().nlargest(self.top_k).index.tolist()\n",
    "        return self\n",
    "    def transform(self, X):\n",
    "        X_t = X.copy()\n",
    "        for col in X_t.columns:\n",
    "            top = self.top_categories_.get(col, [])\n",
    "            X_t[col] = X_t[col].where(X_t[col].isin(top), other='__other__')\n",
    "        return X_t\n",
    "\n",
    "def make_preprocessor(num_cols, cat_cols, strategy='tree', top_k=50):\n",
    "    # numeric pipeline (impute -> scale)\n",
    "    num_pipe = Pipeline([\n",
    "        ('imputer', SimpleImputer(strategy='median')),\n",
    "        ('scaler', StandardScaler())\n",
    "    ])\n",
    "    # categorical grouping then encoder\n",
    "    cat_group = TopKCategoricalGrouper(top_k=top_k)\n",
    "    if strategy == 'tree':\n",
    "        cat_pipe = Pipeline([\n",
    "            ('group', cat_group),\n",
    "            ('imputer', SimpleImputer(strategy='constant', fill_value='__missing__')),\n",
    "            ('ord', OrdinalEncoder(handle_unknown='use_encoded_value', unknown_value=-1))\n",
    "        ])\n",
    "    else:\n",
    "        # linear models -> OHE (sparse)\n",
    "        cat_pipe = Pipeline([\n",
    "            ('group', cat_group),\n",
    "            ('imputer', SimpleImputer(strategy='constant', fill_value='__missing__')),\n",
    "            ('ohe', OneHotEncoder(handle_unknown='ignore', sparse_output=True))\n",
    "        ])\n",
    "    preprocessor = ColumnTransformer([\n",
    "        ('num', num_pipe, num_cols),\n",
    "        ('cat', cat_pipe, cat_cols)\n",
    "    ], remainder='drop')\n",
    "    return preprocessor\n",
    "\n",
    "# quick utility: display metrics & plot\n",
    "def display_metrics(y_true, y_pred, name='Model'):\n",
    "    r2 = r2_score(y_true, y_pred)\n",
    "    mse = mean_squared_error(y_true, y_pred)\n",
    "    rmse = np.sqrt(mse)\n",
    "    mae = mean_absolute_error(y_true, y_pred)\n",
    "    print(f"{name} Metrics")\n",
    "    print(f"R2 Score: {r2:.4f}")\n",
    "    print(f"MSE: {mse:,.2f}")\n",
    "    print(f"RMSE: €{rmse:,.2f}")\n",
    "    print(f"MAE: €{mae:,.2f}\n")\n",
    "\n",
    "def plot_actual_vs_predicted(y_true, y_pred, name='Model'):\n",
    "    plt.figure(figsize=(8,6))\n",
    "    plt.scatter(y_true, y_pred, alpha=0.3)\n",
    "    mn = min(y_true.min(), y_pred.min())\n",
    "    mx = max(y_true.max(), y_pred.max())\n",
    "    plt.plot([mn,mx],[mn,mx],'r--')\n",
    "    plt.xlabel('Actual')\n",
    "    plt.ylabel('Predicted')\n",
    "    plt.title(name + ' - Actual vs Predicted')\n",
    "    plt.grid(True)\n",
    "    plt.show()\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Feature selection and train/test split\n",
    "\n",
    "We pick sensible numeric and categorical features. You can adapt these lists to your domain knowledge. We split first and then fit preprocessor on X_train only to avoid leakage."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# define features (try to be explicit)\n",
    "# If columns are missing adapt the lists (we use intersection to be robust)\n",
    "default_num = ['latitude','longitude','price','livable_surface','total_surface','garage','terrace','swimming_pool','energy_consumption_kWh/m2/year','preschool_distance_m','train_station_distance_m','supermarket_distance_m','nearest_city_distance_km','price_per_m2']\n",
    "default_cat = ['property_type','city','province','property_state','nearest_city']\n",
    "\n",
    "available = set(df_cleaned.columns)\n",
    "num_cols = [c for c in default_num if c in available and c != 'price']\n",
    "cat_cols = [c for c in default_cat if c in available]\n",
    "print('Numeric features used:', num_cols)\n",
    "print('Categorical features used:', cat_cols)\n",
    "\n",
    "# prepare X, y and drop rows without price or livable_surface\n",
    "df_model = df_cleaned.dropna(subset=['price','livable_surface']).copy()\n",
    "X = df_model[num_cols + cat_cols]\n",
    "y = df_model['price']\n",
    "\n",
    "# split BEFORE fitting any transformer\n",
    "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2, random_state=RANDOM_STATE)\n",
    "print('Train size:', X_train.shape, 'Test size:', X_test.shape)\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Model 1 — Linear Regression (baseline)\n",
    "We use the linear pipeline with OneHotEncoder for categorical features (sparse). Target is log1p transformed. This gives a baseline." 
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# build preprocessor for linear model\n",
    "preprocessor_linear = make_preprocessor(num_cols, cat_cols, strategy='linear', top_k=50)\n",
    "linear = TransformedTargetRegressor(regressor=Pipeline([('pre', preprocessor_linear), ('lr', LinearRegression())]), func=np.log1p, inverse_func=np.expm1)\n",
    "\n",
    "# Fit and evaluate with cross-validation on train set\n",
    "cv_scores = cross_val_score(linear, X_train, y_train, cv=5, scoring='r2', n_jobs=-1)\n",
    "print('Linear regression CV R2 mean:', cv_scores.mean(), 'std:', cv_scores.std())\n",
    "linear.fit(X_train, y_train)\n",
    "y_pred = linear.predict(X_test)\n",
    "display_metrics(y_test, y_pred, 'Linear Regression')\n",
    "plot_actual_vs_predicted(y_test, y_pred, 'Linear Regression')\n",
    "joblib.dump(linear, os.path.join(MODEL_DIR, 'linear_pipeline.joblib'))\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Model 2 — Random Forest (recommended)\n",
    "We use Ordinal encoding for categorical features and log1p target transform. RandomForest with n_jobs=-1 and oob_score when possible." 
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "preprocessor_tree = make_preprocessor(num_cols, cat_cols, strategy='tree', top_k=50)\n",
    "rf = TransformedTargetRegressor(regressor=Pipeline([('pre', preprocessor_tree), ('rf', RandomForestRegressor(n_estimators=200, n_jobs=-1, random_state=RANDOM_STATE))]), func=np.log1p, inverse_func=np.expm1)\n",
    "\n",
    "# quick CV check on train set\n",
    "cv_scores_rf = cross_val_score(rf, X_train, y_train, cv=3, scoring='r2', n_jobs=-1)\n",
    "print('RandomForest CV R2 mean:', cv_scores_rf.mean(), 'std:', cv_scores_rf.std())\n",
    "\n",
    "# fit on train and evaluate on test\n",
    "rf.fit(X_train, y_train)\n",
    "y_pred_rf = rf.predict(X_test)\n",
    "display_metrics(y_test, y_pred_rf, 'Random Forest')\n",
    "plot_actual_vs_predicted(y_test, y_pred_rf, 'Random Forest')\n",
    "joblib.dump(rf, os.path.join(MODEL_DIR, 'rf_pipeline.joblib'))\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Model 3 — XGBoost (alternative)\n",
    "We use Ordinal encoding (trees handle integers well). For XGBoost you may add early stopping by passing fit parameters to the underlying regressor; here we keep a simple pipeline and recommend tuning separately." 
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "preprocessor_xgb = make_preprocessor(num_cols, cat_cols, strategy='tree', top_k=50)\n",
    "xgb_reg = xgb.XGBRegressor(n_estimators=1000, learning_rate=0.05, max_depth=6, n_jobs=-1, random_state=RANDOM_STATE, verbosity=0)\n",
    "xgb_pipeline = TransformedTargetRegressor(regressor=Pipeline([('pre', preprocessor_xgb), ('xgb', xgb_reg)]), func=np.log1p, inverse_func=np.expm1)\n",
    "\n",
    "# Fit and evaluate\n",
    "xgb_pipeline.fit(X_train, y_train)\n",
    "y_pred_xgb = xgb_pipeline.predict(X_test)\n",
    "display_metrics(y_test, y_pred_xgb, 'XGBoost')\n",
    "plot_actual_vs_predicted(y_test, y_pred_xgb, 'XGBoost')\n",
    "joblib.dump(xgb_pipeline, os.path.join(MODEL_DIR, 'xgb_pipeline.joblib'))\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Quick diagnostics and next steps\n",
    "- Compare CV scores across models and check train vs test performance to detect overfitting.\n",
    "- Use RandomizedSearchCV or GridSearchCV to tune hyperparameters (n_estimators, max_depth, learning_rate for xgboost).\n",
    "- Add permutation importance or SHAP for feature insights.\n",
    "- Consider binning/postcode clustering and advanced feature engineering (age, distance to city centers)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# Predict helper: loads a saved pipeline and predict for a single record (dict)\n",
    "def predict_from_dict(model_path, record_dict):\n",
    "    mdl = joblib.load(model_path)\n",
    "    df = pd.DataFrame([record_dict])\n",
    "    # ensure same columns are present (use intersection)\n",
    "    prediction = mdl.predict(df)\n",
    "    return prediction[0]\n",
    "\n",
    "# Example usage (replace with a real dict or json file)\n",
    "# sample = X_test.iloc[0].to_dict()\n",
    "# print('Sample prediction (rf):', predict_from_dict(os.path.join(MODEL_DIR,'rf_pipeline.joblib'), sample))\n"
   ]
